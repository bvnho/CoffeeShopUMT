platform :ios, '15.0'
use_frameworks!

target 'CoffeeShopUMT' do
  
  # --- Thư viện hỗ trợ UI ---
  pod 'Kingfisher', '~> 7.0'       # Hỗ trợ load ảnh đồ uống mượt mà
  pod 'IQKeyboardManagerSwift'     # Chống bàn phím che mất chữ khi đăng nhập/nhập liệu
  pod 'Toast-Swift'                # Hiện thông báo nhỏ (vd: "Sai mật khẩu", "Đã thêm vào giỏ")

  # --- Thư viện Data & Network ---
  pod 'Alamofire', '~> 5.8'        # Hỗ trợ gọi API sau này
  pod 'SwiftyJSON' 
  pod 'SnapKit'   # Hỗ trợ code Auto Layout nhanh gọn
  pod 'DGCharts'                # Đọc dữ liệu JSON cho dễ
  pod 'Firebase/Auth'           # Quản lý tài khoản Admin/Staff
  pod 'Firebase/Firestore'
end